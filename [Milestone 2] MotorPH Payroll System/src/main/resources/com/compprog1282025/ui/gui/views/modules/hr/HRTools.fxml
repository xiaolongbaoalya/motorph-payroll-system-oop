<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.compprog1282025.ui.gui.controllers.HRToolsController"
            stylesheets="@/com/compprog1282025/ui/gui/styles/global.css">

    <left>
        <VBox spacing="10" prefWidth="260" style="-fx-background-color: #1e293b;">
            <padding><Insets top="24" right="14" bottom="24" left="14"/></padding>
            <Label text="HR Dashboard" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Button text="Team Attendance" onAction="#showTeamAttendance" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Team Requests" onAction="#showTeamRequests" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Add Employee" onAction="#showAddEmployee" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Button text="Employee Details" onAction="#showEmployeeDetails" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane>
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <VBox fx:id="paneTeamAttendance" spacing="14" VBox.vgrow="ALWAYS">
                <Label text="Team Attendance" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="cmbTeamMonth" promptText="Month"/>
                    <ComboBox fx:id="cmbTeamYear" promptText="Year"/>
                    <Button text="Load Team" onAction="#loadTeamAttendance" styleClass="primary-button"/>
                </HBox>
                <TableView fx:id="tblTeamAttendance" VBox.vgrow="ALWAYS"/>
                <Separator/>
                <Label text="Specific Employee Attendance History" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="txtHistoryEmpNo" promptText="Employee #" prefWidth="140"/>
                    <DatePicker fx:id="dpHistoryFrom" promptText="From"/>
                    <DatePicker fx:id="dpHistoryTo" promptText="To"/>
                    <Button text="Load History" onAction="#loadEmployeeAttendanceHistory" styleClass="primary-button"/>
                </HBox>
                <TableView fx:id="tblEmployeeHistory" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox fx:id="paneTeamRequests" spacing="12" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <Label text="Team Requests" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <HBox spacing="10">
                    <Button text="Approve Selected" onAction="#approveSelectedRequest" styleClass="success-button"/>
                    <Button text="Reject Selected" onAction="#rejectSelectedRequest" styleClass="danger-button"/>
                </HBox>
                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab text="Pending Leave">
                            <content><TableView fx:id="tblPendingLeave"/></content>
                        </Tab>

                        <Tab text="Request History">
                            <content><TableView fx:id="tblRequestHistory"/></content>
                        </Tab>
                    </tabs>
                </TabPane>
            </VBox>

            <VBox fx:id="paneAddEmployee" spacing="12" visible="false" managed="false" maxWidth="520">
                <Label text="Add Employee" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10; -fx-border-color: #e5e7eb; -fx-border-radius: 10;">
                    <Label text="Employee Number" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtAddEmpNo"/>
                    <Label text="First Name" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtAddFirstName"/>
                    <Label text="Last Name" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtAddLastName"/>
                    <Button text="Add Employee" onAction="#addEmployee" styleClass="success-button" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <VBox fx:id="paneEmployeeDetails" spacing="12" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <Label text="Employee Details" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <HBox spacing="16" VBox.vgrow="ALWAYS">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Employee Directory" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <TableView fx:id="tblEmployeeDirectory" VBox.vgrow="ALWAYS"/>
                    </VBox>
                    <VBox spacing="8" prefWidth="320">
                        <Label text="Selected Employee" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <HBox><Label text="Emp #:" style="-fx-font-weight: bold;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblDetailEmpNo" text="-"/></HBox>
                            <HBox><Label text="Name:" style="-fx-font-weight: bold;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblDetailName" text="-"/></HBox>
                            <HBox><Label text="Department:" style="-fx-font-weight: bold;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblDetailDepartment" text="-"/></HBox>
                            <HBox><Label text="Position:" style="-fx-font-weight: bold;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblDetailPosition" text="-"/></HBox>
                            <HBox><Label text="Status:" style="-fx-font-weight: bold;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblDetailStatus" text="-"/></HBox>
                        </VBox>
                    </VBox>
                </HBox>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="View Employee" onAction="#viewSelectedEmployee" styleClass="primary-button"/>
                    <Button text="Update" onAction="#updateSelectedEmployee" styleClass="primary-button"/>
                    <Button text="Archive" onAction="#archiveSelectedEmployee" styleClass="danger-button"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>

