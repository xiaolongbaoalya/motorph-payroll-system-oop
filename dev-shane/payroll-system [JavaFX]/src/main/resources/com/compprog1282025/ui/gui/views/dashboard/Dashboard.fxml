<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../../styles/global.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.compprog1282025.ui.gui.controllers.DashboardController">

    <left>
        <VBox spacing="10" prefWidth="250" style="-fx-background-color: #1e293b;">
            <padding><Insets top="30" right="15" bottom="30" left="15"/></padding>

            <ImageView fitHeight="70" preserveRatio="true">
                <Image url="@/com/compprog1282025/assets/motorph_logo_with_white_outline.png"/>
                <VBox.margin><Insets bottom="20" left="10"/></VBox.margin>
            </ImageView>

            <TitledPane fx:id="panePersonalMenu" text="Personal Dashboard" expanded="true" collapsible="true">
                <content>
                    <VBox spacing="4" style="-fx-background-color: transparent; -fx-padding: 6 0 0 0;">
                        <Button text="My Attendance" onAction="#showAttendance" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="My Payslip" onAction="#showPayslip" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="My Requests" onAction="#showRequests" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="About Me" onAction="#showAboutMe" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                    </VBox>
                </content>
            </TitledPane>

            <TitledPane fx:id="paneHrMenu" text="HR Dashboard" expanded="false" collapsible="true" visible="false" managed="false">
                <content>
                    <VBox spacing="4" style="-fx-background-color: transparent; -fx-padding: 6 0 0 0;">
                        <Button text="Team Attendance" onAction="#showHrTeamAttendance" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="Team Requests" onAction="#showHrTeamRequests" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="Add Employee" onAction="#showHrAddEmployee" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="Employee Details" onAction="#showHrEmployeeDetails" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                    </VBox>
                </content>
            </TitledPane>

            <TitledPane fx:id="paneFinanceMenu" text="Finance Dashboard" expanded="false" collapsible="true" visible="false" managed="false">
                <content>
                    <VBox spacing="4" style="-fx-background-color: transparent; -fx-padding: 6 0 0 0;">
                        <Button text="Generate Payslips" onAction="#showFinGeneratePayslips" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                        <Button text="Employee Payroll History" onAction="#showFinPayrollHistory" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                    </VBox>
                </content>
            </TitledPane>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-opacity: 0.2;"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="0" style="-fx-background-color: #f9fafb;">
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
                <VBox>
                    <Label fx:id="lblWelcome" text="Welcome!" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblDate" text="Date Placeholder" style="-fx-text-fill: #6b7280;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Time In" styleClass="success-button" onAction="#handleTimeIn"/>
                    <Button text="Time Out" styleClass="danger-button" onAction="#handleTimeOut"/>
                </HBox>
            </HBox>

            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
                <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

                <VBox fx:id="paneAttendance" spacing="20" VBox.vgrow="ALWAYS">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="View Records for:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbMonth" promptText="Month"/><ComboBox fx:id="cmbYear" promptText="Year"/>
                    </HBox>
                    <VBox styleClass="kpi-card" maxWidth="Infinity" style="-fx-border-color: #3b82f6;">
                        <Label text="Total Hours Worked" styleClass="kpi-label"/>
                        <Label fx:id="lblTotalHours" text="0.0" styleClass="kpi-value"/>
                    </VBox>
                    <TableView fx:id="tblAttendance" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox fx:id="paneProfile" spacing="12" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="About Me" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                    <HBox spacing="12" alignment="TOP_LEFT" fillHeight="false">
                        <VBox spacing="6" styleClass="kpi-card" HBox.hgrow="ALWAYS" minWidth="0" prefWidth="0" maxWidth="Infinity" style="-fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                            <Label text="Personal Information" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                            <GridPane hgap="10" vgap="6">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="130"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Employee ID:" style="-fx-font-weight: bold;" GridPane.rowIndex="0"/><Label fx:id="lblProfileId" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Full Name:" style="-fx-font-weight: bold;" GridPane.rowIndex="1"/><Label fx:id="lblProfileName" wrapText="true" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS"/>
                                <Label text="Birthday:" style="-fx-font-weight: bold;" GridPane.rowIndex="2"/><Label fx:id="lblProfileBirthday" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <Label text="Phone:" style="-fx-font-weight: bold;" GridPane.rowIndex="3"/><Label fx:id="lblProfilePhone" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <Label text="Address:" style="-fx-font-weight: bold;" GridPane.rowIndex="4"/><Label fx:id="lblProfileAddress" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </GridPane>
                        </VBox>

                        <VBox spacing="6" styleClass="kpi-card" HBox.hgrow="ALWAYS" minWidth="0" prefWidth="0" maxWidth="Infinity" style="-fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                            <Label text="Work Details" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                            <GridPane hgap="10" vgap="6">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="130"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Position:" style="-fx-font-weight: bold;" GridPane.rowIndex="0"/><Label fx:id="lblProfilePosition" wrapText="true" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS"/>
                                <Label text="Department:" style="-fx-font-weight: bold;" GridPane.rowIndex="1"/><Label fx:id="lblProfileDepartment" wrapText="true" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS"/>
                                <Label text="Status:" style="-fx-font-weight: bold;" GridPane.rowIndex="2"/><Label fx:id="lblProfileStatus" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <Label text="Supervisor:" style="-fx-font-weight: bold;" GridPane.rowIndex="3"/><Label fx:id="lblProfileSupervisor" wrapText="true" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.hgrow="ALWAYS"/>
                            </GridPane>
                        </VBox>
                    </HBox>

                    <VBox spacing="6" styleClass="kpi-card" style="-fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                        <Label text="Government Details" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                        <GridPane hgap="14" vgap="6">
                            <columnConstraints>
                                <ColumnConstraints minWidth="140"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints minWidth="140"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="SSS No.:" style="-fx-font-weight: bold;" GridPane.rowIndex="0"/><Label fx:id="lblProfileSSS" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label text="PhilHealth No.:" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="0"/><Label fx:id="lblProfilePhilHealth" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                            <Label text="TIN No.:" style="-fx-font-weight: bold;" GridPane.rowIndex="1"/><Label fx:id="lblProfileTIN" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label text="Pag-IBIG No.:" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="1"/><Label fx:id="lblProfilePagIbig" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        </GridPane>
                    </VBox>
                </VBox>

                <VBox fx:id="panePayslip" spacing="20" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="Select Pay Period:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbPayslipMonth" promptText="Month"/><ComboBox fx:id="cmbPayslipYear" promptText="Year"/>
                        <Button onAction="#refreshPayslipData" styleClass="icon-button"><graphic><Label text="Refresh" style="-fx-font-weight: bold;"/></graphic></Button>
                        <Region HBox.hgrow="ALWAYS"/><Button text="Download PDF" onAction="#handleDownloadPayslip" styleClass="nav-button"/>
                    </HBox>
                    <HBox spacing="20">
                        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" style="-fx-border-color: #10b981;">
                            <Label text="Net Pay" styleClass="kpi-label"/><Label fx:id="lblNetPay" text="PHP 0.00" styleClass="kpi-value" style="-fx-text-fill: #10b981;"/>
                        </VBox>
                        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                            <Label text="Gross Income" styleClass="kpi-label"/><Label fx:id="lblGrossIncome" text="PHP 0.00" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>

                    <GridPane hgap="30" vgap="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-border-color: #e5e7eb; -fx-border-width: 1;">
                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>

                        <VBox spacing="10" GridPane.columnIndex="0">
                            <Label text="EARNINGS" style="-fx-font-weight: bold; -fx-text-fill: #6b7280;"/>
                            <Separator/>
                            <HBox><Label text="Basic Salary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblBasicSalary" text="PHP 0.00"/></HBox>
                            <HBox><Label text="Rice Subsidy" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblRiceSubsidy" text="PHP 0.00"/></HBox>
                            <HBox><Label text="Phone Allowance" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblPhoneAllowance" text="PHP 0.00"/></HBox>
                            <HBox><Label text="Clothing Allowance" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblClothingAllowance" text="PHP 0.00"/></HBox>
                        </VBox>

                        <VBox spacing="10" GridPane.columnIndex="1">
                            <Label text="DEDUCTIONS" style="-fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                            <Separator/>
                            <HBox><Label text="SSS" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblSSS" text="PHP 0.00" style="-fx-text-fill: #ef4444;"/></HBox>
                            <HBox><Label text="PhilHealth" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblPhilHealth" text="PHP 0.00" style="-fx-text-fill: #ef4444;"/></HBox>
                            <HBox><Label text="Pag-IBIG" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblPagIbig" text="PHP 0.00" style="-fx-text-fill: #ef4444;"/></HBox>
                            <HBox><Label text="Withholding Tax" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblTax" text="PHP 0.00" style="-fx-text-fill: #ef4444;"/></HBox>
                        </VBox>
                    </GridPane>

                    <VBox spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-border-color: #cbd5e1; -fx-background-radius: 10;">
                        <HBox><Label text="Total Earnings" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblTotalEarnings" text="PHP 0.00" style="-fx-font-weight: bold;"/></HBox>
                        <HBox><Label text="Total Deductions" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblTotalContribs" text="PHP 0.00" style="-fx-text-fill: #ef4444;"/></HBox>
                        <HBox><Label text="Withholding Tax" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblTotalTax" text="PHP 0.00" style="-fx-text-fill: #ef4444;"/></HBox>
                        <Separator/>
                        <HBox><Label text="FINAL NET PAY" style="-fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Label fx:id="lblFinalNetPay" text="PHP 0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/></HBox>
                    </VBox>
                </VBox>

                <VBox fx:id="paneRequests" spacing="16" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 10; -fx-border-color: #e5e7eb;">
                        <Label text="New Request Application" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        

                        <VBox fx:id="vboxLeaveFields" spacing="10">
                            <Label text="Leave Type"/><ComboBox fx:id="cmbLeaveType" maxWidth="Infinity"/>
                            <HBox spacing="10"><DatePicker fx:id="dpLeaveFrom" HBox.hgrow="ALWAYS" promptText="From"/><DatePicker fx:id="dpLeaveTo" HBox.hgrow="ALWAYS" promptText="To"/></HBox>
                        </VBox>


                        <TextArea fx:id="txtRequestReason" prefHeight="92" promptText="Reason..."/>
                        <Button fx:id="btnSubmitRequest" text="Submit Request" onAction="#handleSubmitRequest" styleClass="success-button" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="8" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Request History" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="View Details" onAction="#handleViewMyRequestDetails" styleClass="primary-button"/>
                        </HBox>
                        <TableView fx:id="tblRequestHistory" VBox.vgrow="ALWAYS">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>

                <VBox fx:id="paneFinGeneratePayslip" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="Generate Payslips" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 16; -fx-border-color: #e5e7eb; -fx-background-radius: 10; -fx-border-radius: 10;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Month" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="cmbFinMonth" prefWidth="170"/>
                            <Label text="Year" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="cmbFinYear" prefWidth="130"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnFinBulkStart" text="Generate Payslips" onAction="#handleFinStartBulkGeneration" styleClass="success-button"/>
                            <Button fx:id="btnFinBulkCancel" text="Cancel" onAction="#handleFinCancelBulkGeneration" styleClass="danger-button" disable="true"/>
                        </HBox>

                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <Label text="Scope:" style="-fx-font-weight: bold;"/>
                            <RadioButton fx:id="rbFinScopeAll" text="All Employees" selected="true"/>
                            <RadioButton fx:id="rbFinScopeSelected" text="Selected Employees"/>                            <Button fx:id="btnFinClearSelection" text="Clear Selection" onAction="#handleFinClearSelection" styleClass="primary-button" disable="true"/>
                        </HBox>

                        <Label fx:id="lblFinSelectionHint" text="Select Employees mode uses checkboxes in the first column." style="-fx-text-fill: #6b7280;"/>

                        <TableView fx:id="tblFinBulkEmployees" VBox.vgrow="ALWAYS">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        </TableView>

                        <ProgressBar fx:id="progressFinBulk" progress="0" maxWidth="Infinity"/>
                        <Label fx:id="lblFinBulkStatus" text="Ready for payslip generation." style="-fx-text-fill: #6b7280;"/>
                    </VBox>
                </VBox>
                <VBox fx:id="paneFinPayrollHistory" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="Employee Payroll History" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Month" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbFinHistoryMonth" prefWidth="160"/>
                        <Label text="Year" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbFinHistoryYear" prefWidth="120"/>
                        <Button text="Load Payroll History" onAction="#handleFinLoadPayrollHistory" styleClass="primary-button"/>
                    </HBox>
                    <TableView fx:id="tblFinPayrollHistory" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                </VBox>
                <VBox fx:id="paneHrTeamAttendance" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="Team Attendance" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbHrTeamMonth" promptText="Month"/>
                        <ComboBox fx:id="cmbHrTeamYear" promptText="Year"/>
                        <Button text="Load Team" onAction="#handleHrLoadTeamAttendance" styleClass="primary-button"/>
                    </HBox>
                    <TableView fx:id="tblHrTeamAttendance" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                    <Separator/>
                    <Label text="Specific Employee Attendance History" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbHrHistoryEmployee" promptText="Employee" editable="true" prefWidth="320"/>
                        <DatePicker fx:id="dpHrHistoryFrom" promptText="From"/>
                        <DatePicker fx:id="dpHrHistoryTo" promptText="To"/>
                        <Button text="Load History" onAction="#handleHrLoadEmployeeHistory" styleClass="primary-button"/>
                    </HBox>
                    <TableView fx:id="tblHrEmployeeHistory" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                </VBox>

                                <VBox fx:id="paneHrTeamRequests" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="Team Requests" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Approve Selected" onAction="#handleHrApproveRequest" styleClass="success-button"/>
                        <Button text="Reject Selected" onAction="#handleHrRejectRequest" styleClass="danger-button"/>
                        <Button text="View Details" onAction="#handleHrViewRequestDetails" styleClass="primary-button"/>
                    </HBox>
                    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab text="Pending Leave Requests">
                                <content>
                                    <TableView fx:id="tblHrPendingLeave" VBox.vgrow="ALWAYS">
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    </TableView>
                                </content>
                            </Tab>

                            <Tab text="Request History">
                                <content>
                                    <TableView fx:id="tblHrRequestHistory" VBox.vgrow="ALWAYS">
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    </TableView>
                                </content>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>

                                <VBox fx:id="paneHrAddEmployee" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="Add Employee" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                    <ScrollPane fitToWidth="true" pannable="true" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox spacing="12">
                                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <Label text="Personal Details" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                    <Label text="Employee #"/><TextField fx:id="txtHrEmpNo" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="First Name"/><TextField fx:id="txtHrFirstName" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Last Name"/><TextField fx:id="txtHrLastName" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Birthday"/><DatePicker fx:id="dpHrBirthday" editable="false" maxWidth="420"/>
                                    <Label text="Address"/><TextArea fx:id="txtHrAddress" prefRowCount="2" wrapText="true" maxWidth="420"/>
                                    <Label text="Phone"/><TextField fx:id="txtHrPhone" styleClass="hr-add-field" maxWidth="420"/>

                                    <Separator/>
                                    <Label text="Government Information" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                    <Label text="SSS #"/><TextField fx:id="txtHrSss" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="PhilHealth #"/><TextField fx:id="txtHrPhilHealth" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="TIN #"/><TextField fx:id="txtHrTin" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Pag-IBIG #"/><TextField fx:id="txtHrPagIbig" styleClass="hr-add-field" maxWidth="420"/>

                                    <Separator/>
                                    <Label text="Work Details" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                    <Label text="Status"/><ComboBox fx:id="cmbHrStatus" maxWidth="420"/>
                                    <Label text="Position"/><TextField fx:id="txtHrPosition" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Department"/><ComboBox fx:id="cmbHrDepartment" maxWidth="420"/>
                                    <Label text="Supervisor"/><ComboBox fx:id="cmbHrSupervisor" editable="true" maxWidth="420"/>

                                    <Separator/>
                                    <Label text="Compensation Details" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                    <Label text="Basic Salary"/><TextField fx:id="txtHrBasicSalary" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Rice Subsidy"/><TextField fx:id="txtHrRiceSubsidy" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Phone Allowance"/><TextField fx:id="txtHrPhoneAllowance" styleClass="hr-add-field" maxWidth="420"/>
                                    <Label text="Clothing Allowance"/><TextField fx:id="txtHrClothingAllowance" styleClass="hr-add-field" maxWidth="420"/>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <Button text="Add Employee" onAction="#handleHrAddEmployee" styleClass="success-button"/>
                                </HBox>
                            </VBox>
                        </content>
                    </ScrollPane>
                </VBox>

                <VBox fx:id="paneHrEmployeeDetails" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <Label text="Employee Details" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <HBox spacing="16" VBox.vgrow="ALWAYS">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Employee Directory" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <TableView fx:id="tblHrEmployeeDirectory" VBox.vgrow="ALWAYS">
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>
                        <VBox spacing="8" prefWidth="360">
                            <Label text="Employee Basic Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <GridPane hgap="12" vgap="10" style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10;">
                                <columnConstraints><ColumnConstraints minWidth="130"/><ColumnConstraints hgrow="ALWAYS"/></columnConstraints>
                                <Label text="Employee #:" GridPane.rowIndex="0"/><Label fx:id="lblHrEmpNo" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Name:" GridPane.rowIndex="1"/><Label fx:id="lblHrEmpName" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Birthday:" GridPane.rowIndex="2"/><Label fx:id="lblHrEmpBirthday" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <Label text="Department:" GridPane.rowIndex="3"/><Label fx:id="lblHrEmpDepartment" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <Label text="Position:" GridPane.rowIndex="4"/><Label fx:id="lblHrEmpPosition" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                <Label text="Status:" GridPane.rowIndex="5"/><Label fx:id="lblHrEmpStatus" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                            </GridPane>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER" spacing="12">
                        <Button text="View Employee" onAction="#handleHrViewEmployee" styleClass="primary-button"/>
                        <Button text="Update Employee" onAction="#handleHrUpdateEmployee" styleClass="primary-button"/>
                        <Button text="Archive Employee" onAction="#handleHrArchiveEmployee" styleClass="danger-button"/>
                        <Button fx:id="btnHrDeleteEmployee" text="Delete Employee" onAction="#handleHrDeleteEmployee" styleClass="danger-button"/>
                    </HBox>
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>


























