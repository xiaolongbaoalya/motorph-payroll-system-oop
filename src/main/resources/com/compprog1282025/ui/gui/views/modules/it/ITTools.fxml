<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.compprog1282025.ui.gui.controllers.ITDashboardController"
      stylesheets="@/com/compprog1282025/ui/gui/styles/global.css"
      spacing="20" VBox.vgrow="ALWAYS">
    
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <Text text="IT Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    
    <HBox spacing="10">
        <Button text="System Health" onAction="#handleSystemHealth" styleClass="primary-button"/>
        <Button text="Database Audit" onAction="#handleSystemAudit" styleClass="primary-button"/>
        <Button text="System Backup" onAction="#handleDatabaseBackup" styleClass="success-button"/>
        <Button text="User Management" onAction="#handleUserManagement" styleClass="primary-button"/>
    </HBox>

    <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
        <Label text="Console Output" style="-fx-font-weight: bold;" />
        <TextArea fx:id="consoleLog" editable="false" VBox.vgrow="ALWAYS"
                  style="-fx-font-family: 'Monospaced'; -fx-control-inner-background: #2f3542; -fx-text-fill: #2ed573;" />
        
        <HBox spacing="20">
             <Label fx:id="systemStatusLabel" text="Status: Checking..." />
             <Label fx:id="databasePathLabel" text="Path: ..." />
        </HBox>
    </VBox>
</VBox>
